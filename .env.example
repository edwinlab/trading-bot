# =============================================================================
# AI Crypto Trading Bot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to git!
# =============================================================================

# --- Exchange API (Binance) ---
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
# IMPORTANT: Only enable "Spot Trading" permission. NEVER enable "Withdrawals".
# For testnet: https://testnet.binance.vision/
EXCHANGE_KEY=your_api_key_here
EXCHANGE_SECRET=your_api_secret_here

# --- Telegram Bot ---
# 1. Talk to @BotFather on Telegram → /newbot → get token
# 2. Talk to @userinfobot → get your chat_id
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- FreqUI API Server ---
# Password for the web dashboard at http://your-server:8080
API_SERVER_PASSWORD=your_secure_password_here
